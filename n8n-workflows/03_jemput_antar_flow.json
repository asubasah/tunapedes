      "parameters": {
        "url": "https://maps.googleapis.com/maps/api/distancematrix/json",
        "sendQuery": true,
        "queryParameters": {
          "parameters": [
            {
              "name": "origins",
              "value": "={{ $('Gemini: Ekstrak Data Jemput').item.json.alamat_jemput }}"
            },
            {
              "name": "destinations",
              "value": "={{ $json.koordinat_lat }},{{ $json.koordinat_lng }}"
            },
            {
              "name": "key",
              "value": "KODE_API_GMAPS_TARUH_DISINI_NANTI"
            }
          ]
