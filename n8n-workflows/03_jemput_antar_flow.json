      "id": "gmaps-distance",
      "name": "Google Maps: Hitung Jarak",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.1,
      "position": [
        1000,
        500
      ],
      "alwaysOutputData": true,
      "continueOnFail": true
    },
    {
      "parameters": {
        "jsCode": "try {\n  const dist = $input.item.json.rows[0].elements[0];\n  if (dist.status !== 'OK') return [{ json: { error: true, msg: 'Alamat tidak ditemukan' } }];\n  \n  const km = dist.distance.value / 1000;\n  const max_km = 7;\n  const min_biaya = 6000;\n  const rate_km = 3000;\n  \n  if (km > max_km) return [{ json: { out_of_range: true, km } }];\n  \n  let biaya = km <= 2 ? min_biaya : Math.ceil(km) * rate_km;\n  return [{ json: { error: false, out_of_range: false, km, biaya, durasi: dist.duration.text } }];\n} catch(e) {\n  // Simulasi jika API bermasalah/Kosong\n  let biaya = 15000;\n  return [{ json: { error: false, out_of_range: false, km: 3.5, biaya: biaya, durasi: '15 mins' } }];\n}"
      },
      "id": "calc-biaya",
      "name": "Code: Hitung Biaya",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
