      "type": "@aldinokemal2104/n8n-nodes-gowa.gowa",
      "typeVersion": 1,
      "position": [1100, 580],
      "credentials": {
        "goWhatsappApi": { "id": "iwMVuTKnzKkCBH6T", "name": "FitMotor GoWA" }
      }
    },

