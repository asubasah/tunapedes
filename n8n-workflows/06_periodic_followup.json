{
  "name": "FitMotor — 06 Periodic Maintenance Follow-up",
  "nodes": [
    {
      "parameters": {
        "rule": { "interval": [{ "field": "cronExpression", "expression": "30 9 * * *" }] }
      },
      "id": "cron-periodic",
      "name": "Setiap Jam 09:30",
      "type": "n8n-nodes-base.cron",
      "typeVersion": 1,
      "position": [200, 300]
    },
    {
      "parameters": {
        "operation": "executeQuery",
        "query": "SELECT * FROM v_periodic_reminder_pending LIMIT 100;",
        "options": {}
      },
      "id": "mysql-get-periodic",
      "name": "MySQL: Get Pending Follow-ups",
      "type": "n8n-nodes-base.mySql",
      "typeVersion": 2.4,
      "position": [420, 300],
      "alwaysOutputData": true,
      "credentials": {
        "mySql": { "id": "On2uunDgsIP8TtL0", "name": "FitMotor MySQL" }
      }
    },
    {
      "parameters": {
        "batchSize": 1,
        "options": {}
      },
      "id": "loop-periodic",
      "name": "Loop Reminder Berkala",
      "type": "n8n-nodes-base.splitInBatches",
      "typeVersion": 3,
      "position": [640, 300]
    },
    {
      "parameters": {
        "mode": "rules",
        "rules": {
          "rules": [
            {
              "conditions": {
                "options": { "leftValue": "", "caseSensitive": true, "typeValidation": "strict", "version": 2 },
                "conditions": [
                  {
                    "id": "h1",
                    "leftValue": "={{ $json.interval_hari }}",
                    "rightValue": 1,
                    "operator": { "type": "number", "operation": "equals" }
                  }
                ],
                "combinator": "and"
              },
              "renameOutput": true,
              "outputKey": "H+1"
            },
            {
              "conditions": {
                "options": { "leftValue": "", "caseSensitive": true, "typeValidation": "strict", "version": 2 },
                "conditions": [
                  {
                    "id": "h30",
                    "leftValue": "={{ $json.interval_hari }}",
                    "rightValue": 30,
                    "operator": { "type": "number", "operation": "equals" }
                  }
                ],
                "combinator": "and"
              },
              "renameOutput": true,
              "outputKey": "H+30"
            },
            {
              "conditions": {
                "options": { "leftValue": "", "caseSensitive": true, "typeValidation": "strict", "version": 2 },
                "conditions": [
                  {
                    "id": "h90",
                    "leftValue": "={{ $json.interval_hari }}",
                    "rightValue": 90,
                    "operator": { "type": "number", "operation": "equals" }
                  }
                ],
                "combinator": "and"
              },
              "renameOutput": true,
              "outputKey": "H+90"
            },
            {
              "conditions": {
                "options": { "leftValue": "", "caseSensitive": true, "typeValidation": "strict", "version": 2 },
                "conditions": [
                  {
                    "id": "h180",
                    "leftValue": "={{ $json.interval_hari }}",
                    "rightValue": 180,
                    "operator": { "type": "number", "operation": "equals" }
                  }
                ],
                "combinator": "and"
              },
              "renameOutput": true,
              "outputKey": "H+180"
            }
          ]
        },
        "options": {}
      },
      "id": "switch-interval",
      "name": "Cek Interval Reminder",
      "type": "n8n-nodes-base.switch",
      "typeVersion": 3,
      "position": [860, 300]
    },

    {
      "parameters": {
        "deviceIdOverride": "={{ $json.device_id }}",
        "phoneNumber": "={{ $json.nomor_wa }}",
        "message": "={{ 'Halo Kak ' + $json.nama_pelanggan + '! 😊\\n\\nSemoga motor *' + $json.nopol + '* yang sudah servis kemarin di FitMotor cabang *' + $json.nama_cabang + '* makin nyaman dikendarai ya!\\n\\nJika ada keluhan atau pertanyaan seputar servis kemarin, jangan ragu hubungi kami. Kami siap bantu! 🙏' }}"
      },
      "id": "gowa-h1",
      "name": "GoWA: Follow-up H+1",
      "type": "@aldinokemal2104/n8n-nodes-gowa.gowa",
      "typeVersion": 1,
      "position": [1100, 100],
      "credentials": {
        "goWhatsappApi": { "id": "iwMVuTKnzKkCBH6T", "name": "FitMotor GoWA" }
      }
    },
    {
      "parameters": {
        "deviceIdOverride": "={{ $json.device_id }}",
        "phoneNumber": "={{ $json.nomor_wa }}",
        "message": "={{ 'Halo Kak ' + $json.nama_pelanggan + '! 🔧\\n\\nTidak terasa sudah *1 bulan* sejak servis *' + $json.jenis_servis + '* di FitMotor cabang *' + $json.nama_cabang + '* lho!\\n\\nJangan lupa rutin cek kondisi oli dan tekanan ban motor *' + $json.nopol + '* ya kak. Performa motor terjaga, perjalanan makin aman! 🏍️\\n\\nButuh servis? Ketik *BOOKING* dan kami siap bantu jadwalkan.' }}"
      },
      "id": "gowa-h30",
      "name": "GoWA: Follow-up H+30",
      "type": "@aldinokemal2104/n8n-nodes-gowa.gowa",
      "typeVersion": 1,
